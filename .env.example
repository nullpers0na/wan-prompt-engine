ANTHROPIC_API_KEY=your_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
POSTGRES_URL=your_postgres_connection_string_here

# Optional: custom system prompt for WhatsApp reply generation
# WHATSAPP_SYSTEM_PROMPT=You are drafting replies on behalf of the user. Be concise.

# Optional: path to Chrome/Chromium if not auto-detected by Puppeteer
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
