# ── Existing WAN Prompt Engine ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your_api_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
POSTGRES_URL=your_postgres_connection_string

# ── AI Companion Chat App ──────────────────────────────────────────────────

# Chat completion endpoint (OpenAI-compatible, e.g. OpenAI, LM Studio, Ollama, vLLM)
CHAT_API_URL=https://api.openai.com/v1
CHAT_API_KEY=sk-...
CHAT_MODEL=gpt-4o

# Path to a plain-text file containing the persona system prompt.
# If not set, falls back to the SYSTEM_PROMPT env var, then "You are a helpful assistant."
SYSTEM_PROMPT_PATH=/path/to/system_prompt.txt
SYSTEM_PROMPT=

# Chat request timeout in milliseconds (default 60000)
CHAT_TIMEOUT_MS=60000

# ComfyUI image generation
IMAGE_API_URL=http://localhost:8188
COMFY_WORKFLOW_PATH=/path/to/workflow.json
COMFY_PROMPT_NODE_ID=6
COMFY_SEED_NODE_ID=3
COMFY_TIMEOUT_MS=120000

# Optional prompt prefix/suffix injected around every image description
# (e.g. quality tags, LoRA triggers, style tokens)
IMAGE_PROMPT_PREFIX=masterpiece, best quality
IMAGE_PROMPT_SUFFIX=

# SQLite database directory (default: ./data/)
COMPANION_DB_DIR=./data

# Server port
PORT=3000
