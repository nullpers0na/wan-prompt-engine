{
  "version": 2,
  "builds": [
    { "src": "api/generate.js",          "use": "@vercel/node", "config": { "maxDuration": 60 } },
    { "src": "api/image-prompt.js",      "use": "@vercel/node", "config": { "maxDuration": 60 } },
    { "src": "api/short.js",             "use": "@vercel/node", "config": { "maxDuration": 60 } },
    { "src": "api/suggest.js",           "use": "@vercel/node", "config": { "maxDuration": 60 } },
    { "src": "api/character-suggest.js", "use": "@vercel/node", "config": { "maxDuration": 15 } },
    { "src": "api/describe.js",          "use": "@vercel/node", "config": { "maxDuration": 60 } },
    { "src": "api/memory.js",            "use": "@vercel/node", "config": { "maxDuration": 30 } },
    { "src": "api/chat.js",              "use": "@vercel/node", "config": { "maxDuration": 60 } },
    { "src": "api/companion/chat.js",               "use": "@vercel/node", "config": { "maxDuration": 300 } },
    { "src": "api/companion/image.js",              "use": "@vercel/node", "config": { "maxDuration": 300 } },
    { "src": "api/companion/conversations.js",      "use": "@vercel/node", "config": { "maxDuration": 15 } },
    { "src": "api/companion/conversations/[id].js", "use": "@vercel/node", "config": { "maxDuration": 15 } },
    { "src": "public/**",    "use": "@vercel/static" },
    { "src": "client/dist/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/generate",          "dest": "/api/generate.js" },
    { "src": "/api/image-prompt",      "dest": "/api/image-prompt.js" },
    { "src": "/api/short",             "dest": "/api/short.js" },
    { "src": "/api/suggest",           "dest": "/api/suggest.js" },
    { "src": "/api/character-suggest", "dest": "/api/character-suggest.js" },
    { "src": "/api/describe",          "dest": "/api/describe.js" },
    { "src": "/api/memory",            "dest": "/api/memory.js" },
    { "src": "/api/chat",              "dest": "/api/chat.js" },
    { "src": "/api/companion/chat",    "dest": "/api/companion/chat.js" },
    { "src": "/api/companion/image",   "dest": "/api/companion/image.js" },
    { "src": "/api/companion/conversations", "dest": "/api/companion/conversations.js" },
    { "src": "/api/companion/conversations/([^/]+)", "dest": "/api/companion/conversations/[id].js?id=$1" },
    { "src": "/companion/assets/(.*)", "dest": "/client/dist/assets/$1" },
    { "src": "/companion(.*)",         "dest": "/client/dist/index.html" },
    { "src": "/",                      "dest": "/public/index.html" },
    { "src": "/(.*)",                  "dest": "/public/$1" }
  ]
}
